{
  "compilerOptions": {
    "target": "ESNext",
    "module": "es2020",
    "esModuleInterop": true,
    "forceConsistentCasingInFileNames": true,
    "strict": true,
    "skipLibCheck": true,
    "outDir": "dist/cjs",
    "rootDir": "src",
    "declaration": true,
    "declarationDir": "dist/cjs",
    "moduleResolution": "bundler",
    "paths": {
      "@src/*": [
        "./src/*"
      ]
    }
  },
}